{
  "name": "iptv-interface",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "proxy": "node server/index.mjs",
    "dev:full": "concurrently \"npm:proxy\" \"npm:dev\"",
    "build": "tsc -b && vite build",
    "build:android": "npm run build && npx cap sync android",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\build-android-debug.ps1",
    "android:install:connected": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\install-firestick.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/instrument-sans": "^5.2.8",
    "concurrently": "^9.2.1",
    "dexie": "^4.3.0",
    "express": "^5.2.1",
    "hls.js": "^1.6.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
